# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=local
DEBUG=true
SECRET_KEY=<generate-with-openssl-rand-hex-32>

# ── Database (Supabase free tier) ─────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:6543/<database>
DATABASE_URL_SYNC=postgresql://<user>:<password>@<host>:6543/<database>

# ── Redis (Upstash free tier) ─────────────────────────────────────────────────
# Get from: https://console.upstash.com/
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
CELERY_BROKER_URL=rediss://default:<password>@<host>.upstash.io:6379/1
CELERY_RESULT_BACKEND=rediss://default:<password>@<host>.upstash.io:6379/2

# ── Auth (Clerk free tier) ────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com/
CLERK_SECRET_KEY=<clerk-secret-key>
CLERK_PUBLISHABLE_KEY=<clerk-publishable-key>
CLERK_WEBHOOK_SECRET=<clerk-webhook-secret>
CLERK_JWKS_URL=<clerk-jwks-url>
CLERK_ISSUER=<clerk-issuer>
CLERK_JWT_AUDIENCE=<clerk-jwt-audience>
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,<production-frontend-origin>

# ── LLM (Groq free: 14,400 req/day) ──────────────────────────────────────────
# Get from: https://console.groq.com/
GROQ_API_KEY=<groq-api-key>

# ── Embeddings (Google Gemini free) ──────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<gemini-api-key>

# ── Vector DB (Pinecone free: 1 index, 100K vectors) ─────────────────────────
# Get from: https://app.pinecone.io/
PINECONE_API_KEY=<pinecone-api-key>
PINECONE_INDEX=regulations

# ── Object Storage (Cloudflare R2 free: 10GB) ────────────────────────────────
# Get from: https://dash.cloudflare.com/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=reguscan
R2_PUBLIC_URL=<r2-public-url>

# ── Email (Resend free: 3K emails/mo) ────────────────────────────────────────
# Get from: https://resend.com/
RESEND_API_KEY=<resend-api-key>
FROM_EMAIL=noreply@yourdomain.com

# Payments (Razorpay - test-only until paid launch validation)
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_PLAN_STARTER=plan_starter_placeholder
RAZORPAY_PLAN_PRO=plan_pro_placeholder
RAZORPAY_CURRENCY=INR

# ── Monitoring (Sentry free: 5K errors/mo) ───────────────────────────────────
# Get from: https://sentry.io/
SENTRY_DSN=<sentry-dsn>

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://app.reguscan.com
